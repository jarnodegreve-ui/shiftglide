{
  "name": "shiftglide",
  "version": "0.1.0",
  "description": "Compliance-checker voor week-planningen van Belgische busoperatoren (EU 561, tachograaf, PC 140.01).",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "preview:web": "vite preview --config web/vite.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.11",
    "vitest": "^2.1.5",
    "xlsx": "^0.18.5"
  }
}
